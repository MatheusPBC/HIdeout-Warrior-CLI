# Hideout Warrior CLI - Supabase Cloud Configuration
# Copie este arquivo para .env e preencha os valores

# ============================================
# CLOUD BACKEND (obrigatório)
# ============================================
# Modo de operação: "supabase" (cloud-first) ou "local"
HW_CLOUD_BACKEND=supabase

# ============================================
# SUPABASE PROJECT (obrigatório para cloud)
# ============================================
# URL do projeto Supabase (encontre em: Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role Key (encontre em: Supabase Dashboard > Settings > API > service_role)
# ATENÇÃO: Esta chave tem permissões admin. Nunca commite em código!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your_service_role_key_here

# ============================================
# SUPABASE STORAGE CONFIG (opcional)
# ============================================
# Bucket para artefatos (deve existir no Supabase Storage)
SUPABASE_STORAGE_BUCKET=hideout-warrior-data

# Prefixo para organizar artefatos no Storage
SUPABASE_STORAGE_PREFIX=hideout-warrior

# Tabelas de catálogo (devem existir no Postgres)
SUPABASE_ARTIFACT_CATALOG_TABLE=artifact_catalog
SUPABASE_ACTIVE_MODELS_TABLE=active_models
SUPABASE_SNAPSHOT_RUNS_TABLE=snapshot_runs
SUPABASE_FIREHOSE_CHECKPOINT_TABLE=firehose_checkpoints
SUPABASE_FIREHOSE_RAW_BUCKET=firehose-raw
SUPABASE_FIREHOSE_RAW_MANIFEST_TABLE=firehose_raw_manifest

# ============================================
# PATH OF EXILE OAUTH (opcional)
# ============================================
POE_OAUTH_CLIENT_ID=your_client_id
POE_OAUTH_CLIENT_SECRET=your_client_secret
POE_OAUTH_TOKEN=
POE_OAUTH_SCOPE=service:psapi
POE_OAUTH_TOKEN_URL=https://www.pathofexile.com/oauth/token

# ============================================
# NOTAS
# ============================================
# 1. HW_CLOUD_BACKEND=supabase ativa o modo cloud-first (default)
# 2. HW_CLOUD_BACKEND=local ativa o modo puramente local (ignora Supabase)
# 3. Se SUPABASE_URL não estiver definido E HW_CLOUD_BACKEND não for explícito,
#    o sistema usa automaticamente local como fallback
# 4. Para CI/CD, defina HW_CLOUD_BACKEND=local se não quiser upload automático
